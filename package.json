{
  "name": "pencachi",
  "version": "0.1.0",
  "private": true,
   "scripts": {
    "dev": "next dev -p 3030",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start -p 3030",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:sync-fixtures": "npx tsx scripts/sync-fixtures.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:readonly": "playwright test --project=readonly",
    "test:e2e:trunk": "cross-env BASE_URL=https://pencachi-trunk.imasdev.com playwright test --project=readonly"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.9.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
