generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  nickname       String   @unique
  fullName       String?
  avatarUrl      String?
  avatarPreset   String?
  favoriteTeamId String?
  isAdmin        Boolean  @default(false)
  isActive       Boolean  @default(true)
  language       String   @default("en")
  createdAt      DateTime @default(now())

  favoriteTeam Team?        @relation(fields: [favoriteTeamId], references: [id])
  predictions           Prediction[]
  comments              Comment[]
  commentLikes          CommentLike[]
  activityLikes         ActivityLike[]
  otpCodes              OtpCode[]
  activities            Activity[]
  weeklyHitsPredictions WeeklyHitsPrediction[]
  nostradamusWins       WeeklyHitsWeek[]       @relation("Nostradamus")
}

model InvitationCode {
  id            String    @id @default(cuid())
  code          String    @unique
  isActive      Boolean   @default(true)
  usageCount    Int       @default(0)
  maxUses       Int       @default(20)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  deactivatedAt DateTime?
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Team {
  id            String  @id @default(cuid())
  apiFootballId Int     @unique
  name          String
  code          String
  flagUrl       String?
  group         String?

  homeMatches          Match[]              @relation("HomeTeam")
  awayMatches          Match[]              @relation("AwayTeam")
  fans                 User[]
  weeklyHitsResults    WeeklyHitsEvent[]    @relation("EventResultTeam")
  weeklyHitsPredictions WeeklyHitsPrediction[] @relation("PredictionTeam")
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

model Match {
  id            String      @id @default(cuid())
  apiFootballId Int         @unique
  homeTeamId    String
  awayTeamId    String
  homeTeam      Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  kickoffTime   DateTime
  stage         String
  group         String?
  venue         String?
  homeScore     Int?
  awayScore     Int?
  status        MatchStatus @default(SCHEDULED)
  minuteClock   String?
  scoreSource   String?
  homeWinProb   Float?
  drawProb      Float?
  awayWinProb   Float?
  analysis      String?
  lastSyncedAt  DateTime?

  predictions Prediction[]
  comments    Comment[]
  activities  Activity[]

  @@index([kickoffTime])
  @@index([status])
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  homeScore Int
  awayScore Int
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  matchId    String?
  parentId   String?
  activityId String?
  text       String
  imageUrl   String?
  createdAt  DateTime @default(now())

  user       User          @relation(fields: [userId], references: [id])
  match      Match?        @relation(fields: [matchId], references: [id])
  parent     Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies    Comment[]     @relation("CommentReplies")
  likes      CommentLike[]
  activities Activity[]
  activity   Activity?     @relation("ActivityReplies", fields: [activityId], references: [id])

  @@index([matchId, createdAt])
  @@index([createdAt])
  @@index([parentId])
  @@index([activityId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  comment Comment @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

enum ActivityType {
  COMMENT
  USER_JOINED
  MATCH_RESULT
  DAILY_HIGHLIGHTS
}

model ActivityLike {
  id         String   @id @default(cuid())
  userId     String
  activityId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id])

  @@unique([userId, activityId])
  @@index([activityId])
  @@index([userId])
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  createdAt DateTime     @default(now())

  commentId String?
  userId    String?
  matchId   String?

  highlightsJson Json?
  highlightsDate DateTime?

  comment Comment?       @relation(fields: [commentId], references: [id])
  user    User?          @relation(fields: [userId], references: [id])
  match   Match?         @relation(fields: [matchId], references: [id])
  likes   ActivityLike[]
  replies Comment[]      @relation("ActivityReplies")

  @@unique([type, commentId])
  @@unique([type, userId])
  @@unique([type, matchId])
  @@unique([type, highlightsDate])
  @@index([createdAt])
  @@index([type, createdAt])
}

model PublishedHighlight {
  id          String   @id @default(cuid())
  nuggetType  String
  dedupeKey   String   @unique
  userId      String?
  matchId     String?
  publishedAt DateTime @default(now())

  @@index([nuggetType])
  @@index([publishedAt])
}

// --- Weekly Hits ---

enum WeekStatus {
  DRAFT
  OPEN
  CLOSED
  RESOLVED
}

enum EventResult {
  HAPPENED
  NO_HAPPENED
}

model WeeklyHitsWeek {
  id             String     @id @default(cuid())
  weekStart      DateTime   @unique
  weekEnd        DateTime
  weekNumber     Int
  status         WeekStatus @default(DRAFT)
  deadline       DateTime
  nostradamusId  String?
  createdAt      DateTime   @default(now())

  nostradamus User?              @relation("Nostradamus", fields: [nostradamusId], references: [id])
  events      WeeklyHitsEvent[]

  @@index([status])
}

model WeeklyHitsEvent {
  id           String       @id @default(cuid())
  weekId       String
  orderIndex   Int
  emoji        String
  title        String
  description  String
  kind         String?
  result       EventResult?
  resultTeamId String?

  week         WeeklyHitsWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  resultTeam   Team?                @relation("EventResultTeam", fields: [resultTeamId], references: [id])
  predictions  WeeklyHitsPrediction[]

  @@unique([weekId, orderIndex])
  @@index([weekId])
}

model WeeklyHitsPrediction {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  teamId    String?
  points    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id])
  event WeeklyHitsEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team  Team?             @relation("PredictionTeam", fields: [teamId], references: [id])

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([userId])
}
